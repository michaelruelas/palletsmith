{
  "name": "palletsmith",
  "version": "0.1.0",
  "description": "A TypeScript-first theme builder that converts a color palette into native themes for any app — Zed, Ghostty, VS Code, Chrome DevTools, OpenChamber.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "palletsmith": "./dist/cli/main.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run test"
  },
  "keywords": ["theme", "color-scheme", "base16", "base24", "zed", "ghostty", "vscode", "palettesmith"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.3.0",
    "palletsmith-plugins": "file:../palletsmith-plugins"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
